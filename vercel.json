{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "functions": {
    "src/app/api/run-pipeline/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/worker/process-next/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/worker/process-next",
      "schedule": "0 0 * * *"
    }
  ]
}